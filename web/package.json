{
  "name": "jianpu-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/jianpu-wasm --target web --out-dir pkg",
    "predev": "wasm-pack build ../crates/jianpu-wasm --target web --out-dir pkg",
    "dev": "vite",
    "prebuild": "wasm-pack build ../crates/jianpu-wasm --target web --out-dir pkg",
    "build": "tsc -b && vite build",
    "check": "knip --include files,dependencies",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "knip": "^6.16.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "wasm-pack": "^0.15.0"
  }
}
